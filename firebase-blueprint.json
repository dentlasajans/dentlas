{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A single blog post article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "excerpt", "content", "slug"]
    }
  },
  "firestore": {
    "/blogs/{blogId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Collection of blog posts."
    }
  }
}
